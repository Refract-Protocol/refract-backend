# ─── Refract Backend configuration ─────────────────────────────────────────────
# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).

# ── HTTP server ──────────────────────────────────────────────────────────────
# Port the API/WebSocket server listens on.
PORT=4001
# Allowed CORS origin (the frontend dev server).
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL 15+) ────────────────────────────────────────────────
# Apply src/db/schema.sql before first run:  psql "$DATABASE_URL" -f src/db/schema.sql
DATABASE_URL=postgres://refract:refract@localhost:5432/refract

# ── Cache / pub-sub (Redis) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stellar / Soroban ────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed contract IDs (see refract-contracts deploy output).
REFRACT_POOL_CONTRACT_ID=
REFRACT_POLICY_CONTRACT_ID=
REFRACT_ORACLE_CONTRACT_ID=

# Relayer/admin secret used to push oracle readings on-chain.
# Use a dedicated, low-value testnet key. NEVER use a mainnet key here.
ORACLE_RELAYER_SECRET=

# ── External oracle data sources ─────────────────────────────────────────────
# CoinGecko, Stellar Horizon, and DeFiLlama are all used for real and need
# no API key for this project's request volume. Overrides below are
# optional — defaults match the values baked into src/config/configuration.ts.
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# DEFILLAMA_BASE_URL=https://api.llama.fi
# Protocol slug DeFiLlama's /protocol/:slug endpoint is polled for the
# SmartContractRisk TVL-drop check — a placeholder "covered protocol"
# until Refract defines a real list.
# DEFILLAMA_PROTOCOL_SLUG=aave
# Timeout (ms) for each oracle HTTP call before it degrades to a safe,
# non-triggering reading (see OracleService.degraded()).
# ORACLE_HTTP_TIMEOUT_MS=5000

# FlightDelay stays mocked: AviationStack requires a paid API key this
# project doesn't have, so there is intentionally no env var for it here.
